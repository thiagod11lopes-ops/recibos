# Supabase — Project Settings > API Keys
# Use a Publishable key (sb_publishable_...) ou a legacy anon key.
# NÃO use a Secret key / service_role no frontend.

VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=

# ID da linha do contrato na tabela contracts
VITE_SUPABASE_CONTRACT_ID=default
